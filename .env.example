# Database (SQLite locally; a persistent file path on Railway)
DATABASE_URL="file:./dev.db"

# Auth.js — generate a secret with: npx auth secret
AUTH_SECRET=""

# Base URL of the app (used for OAuth callbacks)
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client ID)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Admin allowlist — comma-separated emails. Matching accounts become admin on
# login and can access /admin. These admins cannot be demoted/deleted in the UI.
ADMIN_EMAILS="you@example.com"
